<view class="container">
  <view class="card">
    <view class="section-title">审批策略配置</view>
    <view class="subtle mt16">金额阈值（超出需审批）</view>
    <input class="input mt16" type="digit" value="{{config.approvalAmountThreshold}}" data-field="approvalAmountThreshold" bindinput="onConfigInput" />
    <view class="subtle mt16">受控品类（逗号分隔）</view>
    <input class="input mt16" value="{{config.controlledCategoriesText}}" data-field="controlledCategoriesText" bindinput="onConfigInput" />
    <button class="btn-primary mt24" bindtap="onSave">保存配置</button>
  </view>

  <view class="card">
    <view class="section-title">导入模板</view>
    <view class="subtle mt16">员工模板：/miniprogram/templates/employees-import-template.csv</view>
    <view class="subtle mt16">物资模板：/miniprogram/templates/items-import-template.csv</view>
  </view>
</view>
