<view class="container">
  <view class="card">
    <view class="row">
      <view class="section-title">我的领用单</view>
      <button class="btn-ghost" size="mini" bindtap="loadData">刷新</button>
    </view>
    <view class="subtle">状态流转：DRAFT → SUBMITTED → APPROVED/REJECTED → PICKED → COMPLETED</view>
  </view>

  <view class="card" wx:for="{{list}}" wx:key="_id">
    <view class="row">
      <view>
        <view class="title">{{item.no}}</view>
        <view class="subtle mt16">{{item.createdAtText}}</view>
      </view>
      <view class="pill">{{item.status}}</view>
    </view>

    <view class="subtle mt16">用途：{{item.purpose || '-'}}</view>
    <view class="subtle mt16">总金额：¥{{item.totalAmount}}</view>

    <button wx:if="{{item.status === 'PICKED'}}" class="btn-primary mt24" data-id="{{item._id}}" bindtap="confirmComplete">确认收货</button>
  </view>

  <view class="card" wx:if="{{!list.length}}">
    <view class="subtle">暂无申请记录</view>
  </view>
</view>
