@import "../../../../app.wxss";

.item-row {
  border-bottom: 2rpx solid #e2e8f0;
  padding: 18rpx 0;
}

.qty-area {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #e2e8f0;
  border: none;
  border-radius: 12rpx;
  padding: 0;
}

.qty-input {
  width: 80rpx;
  min-height: 56rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 10rpx;
  text-align: center;
}
